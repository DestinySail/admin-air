{
    "version": "2.3.6",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx ./src/scripts/dev.ts",
        "dev:raw": "tsx watch ./src/index.ts",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "tsx ./src/db/migrate.ts",
        "db:seed": "tsx ./src/db/seed.ts",
        "db:setup": "tsx ./src/db/setup.ts",
        "build": "tsc --project ./tsconfig.json --noEmit",
        "start": "tsx ./src/index.ts",
        "lint": "eslint .",
        "lint-fix": "eslint --fix .",
        "format": "prettier --write ."
    },
    "dependencies": {
        "@hono/node-server": "1.19.11",
        "dotenv": "^17.3.1",
        "drizzle-orm": "^0.45.2",
        "hono": "4.12.9",
        "jose": "^6.2.2",
        "postgres": "^3.4.8",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@types/node": "25.5.0",
        "drizzle-kit": "^0.31.10",
        "eslint": "10.1.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "5.5.5",
        "globals": "17.4.0",
        "prettier": "3.8.1",
        "tsx": "4.21.0",
        "typescript": "6.0.2",
        "typescript-eslint": "8.57.2"
    }
}
