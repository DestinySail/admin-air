{
    "name": "baseadmin-air-workspace",
    "version": "2.3.6",
    "private": true,
    "license": "Apache-2.0",
    "type": "module",
    "engines": {
        "node": ">=20.19.0"
    },
    "scripts": {
        "dev": "concurrently \"pnpm --filter @baseadmin-air/mock-server dev\" \"pnpm --filter @baseadmin-air/web dev\"",
        "dev:client": "pnpm --filter @baseadmin-air/web dev",
        "dev:server": "pnpm --filter @baseadmin-air/mock-server dev",
        "build": "pnpm --filter @baseadmin-air/web build && pnpm --filter @baseadmin-air/mock-server build",
        "start": "pnpm --filter @baseadmin-air/mock-server start",
        "lint": "eslint .",
        "lint-fix": "eslint --fix .",
        "format": "npx prettier --write .",
        "typecheck": "pnpm --filter @baseadmin-air/web typecheck && pnpm --filter @baseadmin-air/mock-server build"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "concurrently": "9.2.1",
        "eslint": "10.1.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "5.5.5",
        "eslint-plugin-vue": "10.8.0",
        "globals": "17.4.0",
        "prettier": "3.8.1",
        "typescript-eslint": "8.57.2",
        "vue-eslint-parser": "10.4.0"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@parcel/watcher",
            "esbuild",
            "vue-demi"
        ]
    }
}
